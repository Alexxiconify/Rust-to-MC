# ─── .idea/.gitignore ────────────────────────────────────────────────────────
# Scoped to files inside .idea/ only.
#
# FILES COMMITTED (do not add these):
#   modules.xml        – needed for project structure
#   vcs.xml            – needed for VCS root recognition
#   inspectionProfiles/ – shared code quality rules
#   .gitignore         – this file
#
# EVERYTHING BELOW IS LOCAL / MACHINE-SPECIFIC:

# ─── Local workspace state ───────────────────────────────────────────────────
workspace.xml
tasks.xml
usage.statistics.xml
shelf/
contentModel.xml

# ─── Dictionaries (personal, not shared) ─────────────────────────────────────
dictionaries/

# ─── Caches (rebuilt automatically) ─────────────────────────────────────────
caches/
*.hprof

# ─── Database / data-source tools ────────────────────────────────────────────
dataSources/
dataSources.local.xml
sqlDataSources.xml
dynamic.xml
dbnavigator.xml

# ─── HTTP client ─────────────────────────────────────────────────────────────
httpRequests/

# ─── GitHub Copilot state ────────────────────────────────────────────────────
copilot*.xml
copilot*.json

# ─── Deployment / server config ──────────────────────────────────────────────
deployment.xml
webServers.xml

# ─── SonarLint ───────────────────────────────────────────────────────────────
sonarlint/

# ─── Gradle tool-window cache ────────────────────────────────────────────────
gradle.xml
libraries/
artifacts/

# ─── Run configurations ──────────────────────────────────────────────────────
# Uncomment to stop sharing launch configs:
# runConfigurations/

# ─── Rider nested .idea structure ────────────────────────────────────────────
.idea.*/.idea/

# ─── Module files inside .idea ───────────────────────────────────────────────
*.iml

# ─── JsonAssistant plugin ────────────────────────────────────────────────────
JsonAssistant/

# ─── Git Toolbox plugin ──────────────────────────────────────────────────────
git_toolbox_prj.xml

# ─── Out / generated ─────────────────────────────────────────────────────────
out/
