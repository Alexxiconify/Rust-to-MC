{
  "schemaVersion": 1,
  "id": "rust-mc",
  "version": "${version}",
  "name": "Rust to MC",
  "description": "Optimizing Minecraft with Rust native libraries.",
  "authors": [
    "Alexxiconify"
  ],
  "contact": {
    "homepage": "https://github.com/Alexxiconify/Rust-to-MC",
    "sources": "https://github.com/Alexxiconify/Rust-to-MC"
  },
  "license": "MIT",
  "icon": "assets/rust-mc/icon.png",
  "environment": "*",
  "entrypoints": {
    "preLaunch": [
      "com.alexxiconify.rustmc.PreLaunchHandler"
    ],
    "main": [
      "com.alexxiconify.rustmc.RustMC"
    ],
    "client": [
      "com.alexxiconify.rustmc.RustMCClient"
    ],
    "modmenu": [
      "com.alexxiconify.rustmc.config.ModMenuIntegration"
    ]
  },
  "mixins": [
    "rust-mc.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.1",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": ">=0.141.3"
  }
}